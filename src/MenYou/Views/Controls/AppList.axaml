<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:items="using:MenYou.ViewModels.Items"
             xmlns:loc="using:MenYou.Platform.Windows"
             xmlns:conv="using:MenYou.Views.Converters"
             x:Class="MenYou.Views.Controls.AppList"
             x:Name="Root">
    <ItemsControl ItemsSource="{Binding #Root.Items}">
        <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="items:AppItemViewModel">
                <!-- Same left-edge accent strip pattern as the All Programs
                     tree — keeps the Button.menu rest/hover/pressed
                     chrome untouched so theme transitions stay clean.
                     The Border collapses to zero width when IsNew is
                     false, leaving the row layout identical. -->
                <Button Classes="menu"
                        HorizontalAlignment="Stretch"
                        Margin="6,1"
                        Command="{Binding LaunchCommand}">
                    <Button.ContextMenu>
                        <!-- Verbs ordered to mirror Windows Explorer's
                             right-click context menu for an .exe / .lnk:
                             Open verb first, Run as administrator second,
                             Pin/Unpin and Open new window after a
                             separator. Every label resolves through
                             SHLoadIndirectString so the menu is in the
                             user's Windows display language for free —
                             no per-string localization key needed. -->
                        <ContextMenu>
                            <MenuItem Header="{x:Static loc:Strings.Open}"
                                      Command="{Binding LaunchCommand}" />
                            <MenuItem Header="{x:Static loc:Strings.RunAsAdmin}"
                                      Command="{Binding RunAsAdministratorCommand}" />
                            <Separator />
                            <MenuItem Header="{Binding PinToggleLabel}"
                                      Command="{Binding TogglePinCommand}"
                                      IsVisible="{Binding CanModifyPin}" />
                            <MenuItem Header="{x:Static loc:Strings.OpenFileLocation}"
                                      Command="{Binding OpenFileLocationCommand}" />
                        </ContextMenu>
                    </Button.ContextMenu>
                    <!-- Fixed-width indicator column (3 px bar + 6 px right
                         margin = 9 px) so the icon starts at the same X
                         for both new and non-new rows. -->
                    <Grid ColumnDefinitions="9,Auto,*">
                        <Border Grid.Column="0" Classes="new-indicator"
                                IsVisible="{Binding IsNew}" />
                        <Image Grid.Column="1"
                               Width="20" Height="20"
                               Source="{Binding Icon}"
                               Margin="0,0,10,0" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding DisplayName}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>
                </Button>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>
